{
  "manifest_version": 3,
  "name": "Tab Suspender",
  "version": "1.0.0",
  "description": "Suspends inactive tabs automatically based on URL rules",
  "permissions": ["tabs", "storage", "alarms", "scripting"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
